}</style>		<style id="wp-custom-css">
			/* ============================================================
   BASE
   ============================================================ */

body {
  background-color: transparent !important;
  font-display: swap;
}
 
.site {
  overflow-x: clip;
}

strong {
  font-weight: 600;
}

hr {
  border-color: #181818 !important;
}

*:focus {
  outline: none;
}

::selection {
  background: #0f4ec2 !important;
}

::-webkit-scrollbar {
  width: 16px;
  background-color: #fff;
}

::-webkit-scrollbar-thumb {
  background: #0f4ec2;
  border-radius: 15px;
  border: 3px solid #fff;
}


/* ============================================================
   TYPOGRAPHY
   ============================================================ */

h2 {
  text-transform: inherit !important;
}

label {
  color: #181818 !important;
  font-weight: 700 !important;
}

.main-content .entry-content > * {
  word-spacing: -0.05rem;
}


/* ============================================================
   IMAGES & MEDIA
   ============================================================ */

.wp-block-image img {
  border-radius: 10px;
}

.wp-block-image .aligncenter {
  display: block;
  text-align: center;
}

.wp-block-image .aligncenter > figcaption {
  display: block;
}

.post-thumbnail .post-format {
  display: none !important;
}


/* ============================================================
   BUTTONS & LINKS
   ============================================================ */

.read-more-button {
  border-radius: 3px;
}

.wp-element-button {
  box-shadow: 5px 5px 0px rgba(2, 79, 245, 0.3);
  transition: all 0.15s linear 0s !important;
  top: 0;
  left: 0;
  position: relative;
}

.wp-element-button:hover {
  box-shadow: 0px 0px 0 rgba(2, 79, 245, 0.3);
  transition: all 0.15s linear 0s;
  top: 5px;
  left: 4px;
}

.button-primary {
  border: 2px solid #0f4ec2;
}

.post-more .button {
  text-transform: initial;
  padding: 0.3rem 0.65rem;
  letter-spacing: 0.01rem;
}

.button-effect span {
  -webkit-transition: all 0 ease;
  transition: all 0 ease;
}

.wpnm-button.style-1,
.wpnm-button.style-2,
.wpnm-button.style-3,
.wpnm-button.style-4,
.wpnm-button.style-5 {
  font-size: 11px;
}

.wpnm-button.style-5 .wpnm-button-toggle {
  margin: -0.5em 0.5em;
}


/* ============================================================
   HEADER & NAVBAR
   ============================================================ */

.navbar-dummy {
  height: 0px !important;
}

.navbar {
  border: none !important;
}

.header .site-title {
  transition: all 0.2s ease;
}

.header .site-title:hover {
  font-size: 2.6rem;
  transition: all 0.2s ease;
}

.page-header-type-simple .header,
.page-header-type-none .header,
.page-header-type-wide .header {
  background-color: #fff;
}

.page-header-type-simple .navbar-primary,
.page-header-type-none .navbar-primary {
  box-shadow: 0 5px 15px 5px rgba(0, 0, 0, 0.08);
}

.navbar-primary .cs-container .navbar {
  padding-right: 15px;
  padding-left: 15px;
}

.navbar-primary .navbar .navbar-search {
  margin-top: 0.4rem !important;
}

.navbar-primary .navbar-brand {
  white-space: nowrap;
}

.navbar-primary a,
.navbar-primary button,
.navbar-primary .navbar-nav > li > a {
  padding: 0 30px;
}

#masthead .navbar-nav > li {
  margin: 0;
}

#menu-header-1 .navbar-nav {
  width: 80%;
}

.page-header-type-simple .navbar-nav > li:hover,
.page-header-type-none .navbar-nav > li:hover,
.page-header-type-large .sticky-nav li:hover {
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 50%, #fbfcfc 100%);
}

.site-inner .page-header-type-simple .navbar-nav > li:hover a,
.site-inner .page-header-type-none .navbar-nav > li:hover a,
.site-inner .page-header-type-large .sticky-nav li:hover a {
  color: #0f4ec2 !important;
}

.page-header-type-wide .navbar-nav > li:hover {
  background: linear-gradient(180deg, #f5f5f5 0%, #fff 50%, #fbfcfc 100%);
}

.site-inner .page-header-type-wide .navbar-nav > li:hover a {
  color: #0f4ec2 !important;
}

.sticky-type-slide .navbar-primary.sticky-nav.sticky-nav-slide-visible {
  box-shadow: 1px 1px 5px rgba(0, 0, 0, 0.2);
}

.sticky-nav .sub-menu li:hover {
  background: none !important;
}

.cnvs-block-section-content {
  max-width: 100% !important;
}


/* ============================================================
   SUB-MENUS
   ============================================================ */

.navbar-nav .sub-menu {
  background-color: #fff !important;
  border: none !important;
}

.navbar-nav .sub-menu > li {
  white-space: nowrap;
}

.navbar-nav .sub-menu > li + li > a,
.navbar-nav .cs-mm-categories > li + li > a {
  border-top: 0 !important;
}

.navbar-nav .sub-menu .current-menu-item > a {
  color: initial !important;
}

.navbar-nav .sub-menu .current-menu-parent > a {
  color: #000 !important;
}

.navbar-nav .sub-menu > li > a:hover {
  color: #075cc5 !important;
}

.navbar-nav .sub-menu a:hover {
  padding-left: 0.5rem;
  font-weight: bold;
}

.menu-item-has-children a {
  padding-bottom: 0px;
}


/* ============================================================
   OFFCANVAS
   ============================================================ */

.offcanvas {
  width: 350px;
  left: -350px;
}

.offcanvas .offcanvas-header .navbar-brand {
  margin-left: 3rem;
}

.offcanvas .offcanvas-inner {
  padding: 1.5rem 0rem 2rem 2.5rem;
}

/* Fusion des deux règles dupliquées sur .offcanvas-sidebar .pk-social-links-link */
.offcanvas-sidebar .pk-social-links-wrap .pk-social-links-link .pk-social-links-icon {
  font-size: 1.5rem !important;
}

body .offcanvas-sidebar .pk-social-links-link,
.offcanvas-sidebar .pk-social-links-link {
  padding: 0.5rem 0.5rem 1rem 0 !important;
}

.offcanvas-sidebar .widget {
  margin-bottom: 0;
  padding-bottom: 1rem;
}

.offcanvas-sidebar .widget:last-child {
  padding-bottom: 30px;
}

.offcanvas-sidebar .widget-body {
  margin-top: 1rem;
}

.offcanvas-sidebar .title-block {
  margin-bottom: 0;
}

.offcanvas-sidebar .menu-item-object-post_tag,
.offcanvas-sidebar .menu-item-object-category,
.offcanvas-sidebar .menu-item-object-page,
.offcanvas-sidebar .menu-item-object-post {
  padding-bottom: 0.6rem;
}

.offcanvas-sidebar .menu-item-object-post_tag a,
.offcanvas-sidebar .menu-item-object-category a,
.offcanvas-sidebar .menu-item-object-page a {
  font-size: 0.9rem !important;
}

.offcanvas-sidebar .menu-item a::before {
  content: "";
  display: inline;
  margin-right: 10px;
  border-left: 6px solid #0f4ec2;
  font-size: 1rem;
}

.offcanvas-sidebar .menu-item .sub-menu a::before {
  content: "";
  display: inline-block;
  margin-right: 10px;
  height: 6px;
  width: 6px;
  border-color: #0f4ec2 !important;
  border-radius: 50%;
  vertical-align: middle;
}

.offcanvas-sidebar .menu-item:nth-last-of-type(4) a::before { border-color: #ff5700; }
.offcanvas-sidebar .menu-item:nth-last-of-type(3) a::before { border-color: #ffca00; }
.offcanvas-sidebar .menu-item:nth-last-of-type(2) a::before { border-color: #5bb805; }
.offcanvas-sidebar .menu-item:nth-last-of-type(1) a::before { border-color: #c349ff; }


/* ============================================================
   WIDGET NAV MENU (offcanvas)
   ============================================================ */

.widget_nav_menu .menu-item-has-children > ul {
  display: block !important;
}

.widget_nav_menu .menu-item-has-children > span:after {
  content: none;
}

.widget_nav_menu .menu > .menu-item > .sub-menu {
  padding-bottom: 0rem;
  padding-top: 0.7rem;
}

.widget_nav_menu .menu-item:not(.menu-item-has-children) > a:after {
  display: none;
}


/* ============================================================
   HEADER LIGHT / OVERLAY
   ============================================================ */

.header-light .site-title,
.header-light .navbar-toggle,
.overlay-inner .post-categories a,
.overlay-inner h1,
.overlay-inner h2,
.page-header-type-large .navbar-primary:not(.sticky-nav) .nav > li > a,
.page-header-type-large .navbar-primary:not(.sticky-nav) .site-title,
.overlay-inner li {
  color: #fff !important;
  text-shadow: 0 0 4px #222;
}

.page-header-type-large .navbar-primary:not(.sticky-nav) .nav > li > a:hover,
.header-light .site-title:hover,
.header-light .site-title:focus,
.header-light .navbar-toggle:hover,
.header-light .navbar-toggle:focus .overlay-inner li:hover {
  color: #fff !important;
  text-shadow: 0 0 10px #000;
}

.overlay-inner {
  padding: 0 1rem 1rem 1.5rem;
}

.overlay-inner li {
  font-weight: 700;
}

.overlay-inner a {
  color: #fff !important;
}

.overlay .overlay-media:before,
.post-thumbnail:before,
.pagination-visible .pagination-title {
  background-color: rgba(40, 40, 40, 0.125);
}

.overlay:hover .overlay-media:before,
.post-thumbnail:hover:before,
.pagination-visible:hover .pagination-title {
  background-color: rgba(40, 40, 40, 0.41);
}


/* ============================================================
   SITE CONTENT & LAYOUT
   ============================================================ */

.site-content {
  margin-top: 1.5rem;
  margin-bottom: 2.3rem;
}

.cs-container .nav-links {
  margin-top: 1rem;
}

.nav-links .dots {
  color: #777;
}

.nav-links .current {
  color: #777;
}

.post-more {
  margin-top: 0.5rem;
}

.post-list + .post,
.post + .post-list {
  margin-top: 0;
  padding-top: 2rem;
}

.post-grid .post-inner + .post-inner {
  margin-top: 0.7rem;
  margin-bottom: 1.5rem;
  padding: 0.2rem 0.6rem 0.2rem 0rem;
}

.post-grid .meta-category ul {
  margin-bottom: 0.7rem;
}

.post-list:not(.post-featured) + .post-list:not(.post-featured) {
  border-top-color: #e9ebee !important;
}

.post-archive .post-categories a {
  font-weight: 600;
}

.post-archive .post-categories li {
  margin-right: 0.5rem;
}

.post-archive .post-categories li + li {
  margin-left: 0;
}

.post-archive .post-inner .post-meta,
.post-list .post-more:not(:last-child),
.post-thumbnail .post-meta,
.post-thumbnail .post-more {
  display: none;
}

.post-archive article .button-primary,
.home .post-archive article .button-primary,
.archive article .button-primary,
.search article .button-primary {
  background-color: transparent;
}

.home .post-archive article .button-primary:hover,
.archive .button-primary:hover,
.search .button-primary:hover {
  background-color: #0f4ec2 !important;
}

.archive article .post-grid .post-inner + .post-inner,
.search article .post-grid .post-inner + .post-inner {
  position: relative !important;
}

.archive .post-outer .post-inner + .post-inner a:before,
.search .post-outer .post-inner + .post-inner a:before {
  z-index: 2;
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
}

.style-align-left .post-featured .overlay-inner {
  padding-bottom: 2rem;
}

.style-align-left .post-masonry .post-inner + .post-inner .post-more,
.style-align-left .post-grid .post-inner + .post-inner .post-more {
  position: absolute;
  bottom: 0;
  margin-bottom: 1rem;
}

#content ul li ul {
  margin-top: 0.6rem;
  padding-left: 1.2rem;
}

#content ul li ul li {
  padding-bottom: 0.4rem;
}

.page-header a:hover {
  text-decoration: underline;
}

.search .page-header-simple {
  margin-bottom: 1.5rem;
}

.cs-icon-arrow-right:before {
  font-weight: 600;
  color: #fff;
  padding: 0.18rem 0.65rem;
  content: "Lire la suite »";
  letter-spacing: 0.01rem;
  padding-top: 0.1rem;
  font-family: worksans-600;
  font-size: 0.8rem;
  display: block;
}


/* ============================================================
   SIDEBAR
   ============================================================ */

.sidebar-area {
  padding: 0 !important;
}


/* ============================================================
   FOOTER
   ============================================================ */

.site-footer {
  box-shadow: 0 0 10px 2px rgba(96, 96, 96, 0.35);
  z-index: 2;
  position: relative;
}

.footer-section .navbar-nav > li > a {
  font-size: 0.75rem;
  text-transform: initial;
  letter-spacing: -0.02rem;
}

/* Fusion des deux règles dupliquées sur .footer-section>.cs-container>* */
.footer-section > .cs-container > * {
  padding-top: 1.5rem;
  padding-bottom: 1rem !important;
}

.footer-copyright {
  font-size: 0.8rem;
  line-height: 1.5rem !important;
  display: inline-block;
}

.copyright {
  text-align: center;
  font-size: 0.8rem;
  margin-top: 0.5rem;
}

.footer-info .site-title {
  z-index: 1;
  position: relative;
  background-color: #f9f9f9;
}

.footer-info .site-title::after {
  content: '';
  z-index: 2;
  background-color: #f9f9f9;
  position: absolute;
  top: -20%;
  bottom: -20%;
  width: 0.5em;
  transform: translate3d(-1800%, 0, 0) rotate(30deg);
}

.footer-info .site-title:hover::after {
  transition: transform 0.5s ease-in-out;
  transform: translate3d(50%, 0, 0) rotate(30deg);
}

.footer-info .navbar-lonely {
  width: 100%;
}

.navbar-footer .navbar-nav {
  text-align: center;
}

.navbar-footer {
  margin-bottom: 0;
  margin-top: 0.5rem;
}

.site-footer .site-title {
  margin-right: 1rem;
  width: 100%;
  text-align: center;
  font-size: 2.2rem !important;
}

.footer-info .navbar-nav li {
  padding-bottom: 10px;
  margin-left: 1rem !important;
  margin-right: 1rem !important;
}


/* ============================================================
   SEARCH
   ============================================================ */

#main .search-field {
  background-color: #fff;
}

#search .cs-input-group {
  background-color: #f6f6f6;
}

#search p {
  color: #181818;
}

#search .sr-only {
  font-size: 1rem;
  margin-bottom: 0.7rem;
}

.error404 .cs-input-group-btn {
  margin-left: 1rem;
}


/* ============================================================
   WIDGETS
   ============================================================ */

.powerkit_social_links_widget .title-widget {
  margin-bottom: 0rem;
}

.custom_html-18 .title-widget {
  margin-bottom: 1rem;
}

.custom_html-18 {
  margin-bottom: 5rem !important;
  margin-top: 0.5rem;
}

.custom_html-16 {
  margin-top: 2.5rem !important;
}


/* ============================================================
   SOCIAL LINKS (PowerKit)
   ============================================================ */

.pk-social-links-wrap {
  --pk-social-link-color: #000;
  --pk-social-links-label-color: rgba(0, 0, 0, 0.3);
  --pk-social-links-icon-color: inherit;
  --pk-social-links-title-color: inherit;
  --pk-social-nav-count-color: rgba(0, 0, 0, 0.5);
  --pk-social-bold-title-color: #000;
  --pk-social-inverse-link-color: #fff;
  --pk-social-light-bg-link-background: #f8f9fa;
  --pk-social-light-bg-hover-color: #fff;
  --pk-social-light-bg-hover-title-color: #fff;
  --pk-social-light-bg-hover-label-color: rgba(255, 255, 255, 0.75);
  --pk-social-light-bg-hover-count-color: rgba(255, 255, 255, 0.75);
  --pk-social-bold-bg-link-color: #fff;
  --pk-social-dark-link-background: #000;
  --pk-social-dark-link-color: #fff;
  --pk-social-dark-link-hover-background: #1a1919;
  --pk-social-light-rounded-icon-background: #f8f9fa;
  --pk-social-light-rounded-title-color: #000;
  --pk-social-bold-rounded-icon-background: #f8f9fa;
  --pk-social-bold-rounded-icon-color: #fff;
  --pk-social-bold-rounded-title-color: #000;
  --pk-social-dark-rounded-link-background: #000;
  --pk-social-dark-rounded-link-color: #fff;
  --pk-social-dark-rounded-link-hover-background: #1a1919;
  --pk-social-links-title-font-size: 0.875rem;
  --pk-social-vertical-icon-font-size: 110%;
}

.pk-social-links-wrap .pk-social-links-link .pk-social-links-icon {
  font-size: 2rem !important;
}

.pk-social-links-wrap .pk-social-links-link .pk-social-links-icon,
.pk-social-links-icon,
.pk-social-links-count,
.pk-social-links-label,
.pk-social-links-title {
  -webkit-transition: color 0.2s;
  transition: color 0.2s;
}

.pk-social-links-items {
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -ms-flex-wrap: wrap;
  flex-wrap: wrap;
  margin: 0 -0.125rem;
  justify-content: center;
}

.pk-social-links-template-inline .pk-social-links-item {
  padding-top: 0.5rem;
  padding-bottom: 0.5rem;
  min-width: 3.5rem;
}

.pk-social-links-item .pk-social-links-link {
  display: -webkit-box;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-flex: 1;
  -ms-flex-positive: 1;
  flex-grow: 1;
  -webkit-box-orient: vertical;
  -webkit-box-direction: normal;
  -ms-flex-direction: column;
  flex-direction: column;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  height: 100%;
  line-height: 1;
  text-align: center;
  color: var(--pk-social-link-color);
  border: none !important;
  text-decoration: none !important;
  -webkit-box-shadow: none !important;
  box-shadow: none !important;
  -webkit-transition: background-color 0.2s;
  transition: background-color 0.2s;
}

.pk-social-links-facebook .pk-social-links-link:hover .pk-social-links-icon { color: #3b5998; }
.pk-social-links-microblog .pk-social-links-link:hover .pk-social-links-icon { color: #fd9c3b; }
.pk-social-links-instagram .pk-social-links-link:hover .pk-social-links-icon { color: #d8003e; }
.pk-social-links-twitter .pk-social-links-link:hover .pk-social-links-icon { color: #00aced; }

.pk-icon-youtube:before {
  color: #fc0000;
}

.pk-social-links-wrap .pk-social-links-link .pk-social-links-icon {
  font-size: 1.4rem;
  margin: 0.4rem;
}




/* ============================================================
   MISC / THIRD PARTY
   ============================================================ */

/* Masquer logo cookie */
div[class^="sd-cmp-"] > svg {
  display: none !important;
}

body .crisp-client .cc-tlyw .cc-qfnu {
  background-color: #0f4ec2 !important;
}

.google-auto-placed {
  margin: 0px 0 25px 0;
}

.google::before {
  content: "";
  display: inline-block;
  width: 25px;
  height: 25px;
  background-image: url('https://www.docteur-fitness.com/wp-content/uploads/2023/06/google-news-docteur-fitness.png');
  background-size: contain;
  background-repeat: no-repeat;
  margin-right: 9px;
  margin-left: 2px;
  vertical-align: middle;
}


/* ============================================================
   MEDIA QUERIES
   ============================================================ */



/* ---- max-width: 768px ---- */
@media only screen and (max-width: 768px) {
	
	  .search .post-grid .post-inner + .post-inner {
    position: relative;
  }

  .footer-copyright {
    line-height: 1.3rem !important;
  }
	
	
	
  .cs-container {
    padding-right: 20px;
    padding-left: 20px;
  }

  .page-header-simple + .post-archive {
    border-top: 1px #c9c9c9 solid;
  }

  .post-archive article + .widget {
    margin-top: 2rem;
  }

  .post-archive .widget + article {
    margin-top: 2.5rem;
  }

  .style-align-left .post-grid .post-inner + .post-inner .post-more,
  .home .post-list .post-more {
    position: relative;
    text-align: right;
    margin-bottom: 0;
    width: 98%;
    padding-top: 0.5rem;
  }

  .home .post-list .post-list-content .post-excerpt {
    margin-bottom: 0.8rem;
  }

  .home .post-archive .post-list .post-inner + .post-inner {
    margin-top: 0.9rem !important;
  }

  .code-ads-8 {
    margin-bottom: 0px !important;
  }
	
	
	  .home .post-list .post-list-one-third,
  .archive .post-outer,
  .search .post-outer {
    display: inline-block;
  }

  .home .post-list .post-list-media,
  .archive .post-grid .post-thumbnail,
  .search .post-grid .post-thumbnail {
    float: right;
    margin: 0.5rem;
    margin-right: 0;
  }

  .home .post-list .post-list-content .entry-header,
  .archive .post-grid .post-inner .entry-header,
  .search .post-grid .post-inner .entry-header {
    padding-right: 0.5rem;
    margin-bottom: 0;
    padding-bottom: 0.6rem;
  }

  .home .post-list .post-list-content .entry-title,
  .archive .post-grid .post-inner .entry-title,
  .search .post-grid .post-inner .entry-title {
    font-size: 1.2rem;
    letter-spacing: -0.05em;
    padding-top: 5px;
  }

  .home .post-list .post-list-content .post-excerpt,
  .archive .post-grid .post-inner .post-excerpt,
  .search .post-grid .post-inner .post-excerpt {
    margin-top: 0rem;
    font-size: 0.875rem;
  }

  .home .main-content .post-archive .post-list .post-inner + .post-inner,
  .archive .main-content .post-archive .post-grid .post-inner + .post-inner,
  .search .main-content .post-archive .post-grid .post-inner + .post-inner {
    margin-top: 0 !important;
  }

  .home .post-archive article {
    padding: 15px 15px;
  }

  .home .post-list + .post,
  .home .post + .post-list {
    margin-top: 0;
  }

  .home .post-archive article:first-child,
  .home .post-archive article:nth-child(2n+1) {
    background-color: #f3f3f3;
  }

  .home.paged .site-content,
  .home.paged .archive-main {
    margin-top: 0;
  }
	
  .sidebar .widget + .widget {
    margin-top: 3rem;
    margin-bottom: 2rem;
  }

  .style-align-left .post-featured .overlay-inner {
    padding-bottom: 2rem;
  }

  .footer-section > .cs-container > * {
    padding-top: 1rem;
  }

 
	
	
}



/* ----pour affichage menu tablette ---- */
@media only screen and (min-width: 1120px) {
	.cs-d-lg-none { display: block!important; }
	
}


/* ---- max-width: 1120px ---- */
@media only screen and (max-width: 1120px) {
	
	  .site-inner .layout-sidebar .content-area {
    border: none;
    padding-bottom: 0;
    margin-bottom: 2rem;
  }
	
	
	
  .widget_nav_menu .menu > li > a {
    font-size: 1.1rem !important;
  }

  .page-header-simple h1 {
    margin-top: 0.5rem !important;
  }

  .page-header-simple {
    margin-bottom: 0em !important;
  }
	
	 .navbar-primary a,
  .navbar-primary button,
  .navbar-primary .navbar-nav > li > a {   padding: 0;  }
	
.sticky-up ul,
  .sticky-down ul {
    width: 100%;
  }
	
	
}





/* ---- max-width: 1250px ---- */
@media only screen and (max-width: 1250px) {
  .navbar-primary .navbar-nav > li > a {
    padding: 0 28px;
  }
}





/* ---- min-width: 760px  ---- */
@media only screen and (min-width: 760px) {
	
	.navbar-col:last-child > div > :first-child {
    margin-left: 1.5rem;
  }
	
	
  .home .post-list .post-list-one-third .post-list-content {
    padding-right: 15px;
    padding-left: 7px;
  }
}



/* ---- min-width: 1024px ---- */
@media only screen and (min-width: 1024px) {
	
 .home .post-list .post-more {
    text-align: right;
    display: initial;
  }

  .sidebar-1 {
    border-radius: 0 25px 25px 0;
  }
	
  .widget ul {
    margin-left: -0.5rem;
    margin-right: -0.5rem;
  }

  .archive article,
  .search article,
  .single .archive-main article {
    padding-top: 15px;
  }

  .archive article:hover,
  .search article:hover {
    box-shadow: #bbbaba 0 3px 5px;
    border-radius: 1rem 1rem 0 0 !important;
  }

  .archive .post-thumbnail,
  .search .post-thumbnail,
  .single .archive-main .post-thumbnail {
    border-radius: 10px;
  }

  .home .post-list {
    padding: 1.5rem;
  }

  .home .post-list:hover {
    background-color: #f2f3f3;
    box-shadow: 0 4px 15px 0 rgba(40, 44, 53, 0.18), 0 2px 2px 0 rgba(40, 44, 53, 0.08);
  }

  .overlay .overlay-media:before,
  .post-thumbnail:before,
  .pagination-visible .pagination-title {
    background: linear-gradient(to top, #000000b8, #00000000, transparent) !important;
  }

  .nav-links .prev:hover,
  .nav-links .next:hover {
    padding: 0.2em 0.5em 0.3em 0.7em !important;
    background: #fcfcfc;
  }

  .nav-links .prev:hover {
    border-radius: 8px 0 0 8px;
  }

  .nav-links .next:hover {
    border-radius: 0 8px 8px 0;
  }

  .nav-links .prev,
  .nav-links .next {
    padding: 0.2em 0.5em 0.3em 0.7em !important;
  }

  .nav-links .page-numbers:hover {
    border-bottom: solid 2px #0f4ec2;
    margin-bottom: -2px !important;
  }

  .nav-links .prev:hover,
  .nav-links .next:hover,
  .nav-links .current:hover,
  .nav-links .dots:hover {
    border-bottom: none !important;
    margin-bottom: 0 !important;
  }

  .cs-icon-cross,
  .site-search .close {
    font-weight: 700;
  }

  .widget_nav_menu .menu > .menu-item:not(:first-child) {
    border-top-color: #dbdbdb !important;
  }

  .navbar-nav .sub-menu > li a {
    font-size: 1rem !important;
  }
	
	  .sticky-type-slide .navbar-primary .sticky-up li a {
    font-size: 1.2rem;
  }

  .sticky-nav.sticky-up ul,
  .sticky-nav.sticky-down ul {
    margin-right: 1rem;
  }
	
	 #menu-menu-exercice-1 .sub-menu,
  #menu-programmes-1 .sub-menu,
  #menu-regime-1 .sub-menu {
    column-count: 3;
    column-gap: 1em;
  }

  #menu-menu-exercice-1 li + li ul,
  #menu-regime-1 li + li ul,
  #menu-programmes-1 li + li ul {
    column-count: 1 !important;
  }

  .navbar-nav .sub-menu > li {
    min-height: 40px;
    display: flex;
    align-items: center;
  }

  .navbar-nav .sub-menu > li.menu-item {
    border-bottom: 1px solid #e9ecef;
  }

  .sub-menu {
    background-image: linear-gradient(to bottom, #ffffff, #f9f9f9);
  }

  .navbar-nav .sub-menu > li.menu-item:nth-last-child(-n+1) {
    border-color: #fff;
  }
	
	  .navbar-brand,
  .navbar .wpnm-button {
    display: none;
  }
	
	
}






/* ---- min-width: 1240px ---- */
@media (min-width: 1240px) {
  .cs-container {
    max-width: 1150px;
	 
  }

  .layout-sidebar .content-area {
    -webkit-box-flex: 0 !important;
    -ms-flex: 0 0 760px !important;
    flex: 0 0 760px !important;
    max-width: 760px !important;
  }

  .sidebar-area {
    padding: 0 !important;
  }

  .container-wide .cs-container {
    max-width: 1150px;
  }

  .site-inner .sidebar-1 {
    padding: 1.5rem 1.9rem 2rem;
    margin: 0 0.6rem 2rem;
    background-color: #f9f9f9;
  }
}

/* ---- min-width: 1380px ---- */
@media (min-width: 1380px) {


  .page-header {
    z-index: 10 !important;
  }

  .header-enabled {
    padding-bottom: 0px !important;
  }

  .site-footer {
    z-index: 2;
    position: relative;
  }

  
}

.rank-math-question {cursor: pointer;}

 
