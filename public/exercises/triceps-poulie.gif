<style>/* =====================================================
   BLOCS UTILITAIRES
===================================================== */

/* cache certains items */
.df-hidden-item {
    display: none;
}


/* =====================================================
   BLOC PRINCIPAL : TERM CONDITIONAL LIST (DESKTOP)
===================================================== */

.term-conditional-list {
    position: relative;
    background: #f5f7fa;      /* fond final retenu */
    padding: 28px;
    margin-bottom: 40px;
    border-radius: 10px;
}

/* titre */
.term-conditional-list h2 {
    margin-top: 0;
    font-size: 1.85rem;
}

/* cas où le thème cible le contenu */
.entry-content .term-conditional-list h2 {
    margin-bottom: 18px !important;
}

/* liste */
.term-conditional-list ul {
    margin: 0 !important;
    padding-left: 18px !important;
}

/* items */
.term-conditional-list li {
    margin-bottom: 10px;
    line-height: 1.5;
    padding-bottom: 0;
}

/* liens */
.term-conditional-list a {
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease;
}


/* =====================================================
   HOVER DESKTOP
===================================================== */

@media (min-width: 768px) {

    .term-conditional-list a:hover {
        border-bottom: 1px solid currentColor;
    }

}


/* =====================================================
   BOUTON LOAD MORE + ANIMATIONS
===================================================== */

.df-load-more,
.df-load-more-ajax {
    margin-top: 10px;
    padding: 10px 20px;
    background: linear-gradient(135deg,#2563eb,#1d4ed8);
    color: #fff;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 12px rgba(37,99,235,0.25);
}

.df-load-more:hover,
.df-load-more-ajax:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(37,99,235,0.35);
}

/* loader texte */
.df-loader {
    margin-top: 10px;
    font-size: 13px;
    opacity: 0.7;
}

/* animation apparition */
.df-fade-in {
    opacity: 0;
    transform: translateY(8px);
    transition: all 0.3s ease;
}

.df-fade-in.show {
    opacity: 1;
    transform: translateY(0);
}


/* =====================================================
   VERSION MOBILE (≤768px)
===================================================== */

@media (max-width: 768px) {

    /* container */
    .term-conditional-list {
        padding: 14px 16px;
        border-radius: 12px;
    }

    /* titre */
    .term-conditional-list h2 {
        font-size: 20px;
    }

    /* reset liste mobile */
    .term-conditional-list ul {
        list-style: none;
        margin: 0 !important;
        padding: 0 !important;
    }

    /* items mobile */
    .term-conditional-list li {
        position: relative;
        margin-bottom: 8px;
        line-height: 1.35;
        padding-left: 15px; /* espace pour triangle */
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    .term-conditional-list li:last-child {
        border-bottom: none;
    }

    /* triangle dans le coin */
    .term-conditional-list li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0.5em;
        width: 0;
        height: 0;
        border-top: 9px solid #e43b2c;
        border-right: 9px solid transparent;
    }

    /* liens mobile */
    .term-conditional-list li a {
        display: -webkit-box;
        -webkit-line-clamp: 2;     /* limite à 2 lignes */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        max-height: calc(1.38em * 2);
        font-size: inherit;
        font-weight: 650;
        line-height: 1.35;
        color: #111 !important;
        text-decoration: none;
        padding: 2px 0;
    }

    /* boutons mobile */
    .df-load-more,
    .df-load-more-ajax {
        padding: 10px 18px;
        font-size: 14px;
        width: auto;
        margin-top: 14px;
    }

}</style><script>
