<script type="speculationrules">
{"prerender":[{"source":"document","where":{"and":[{"href_matches":"/*"},{"not":{"href_matches":["/wp-*.php","/wp-admin/*","/wp-content/uploads/*","/wp-content/*","/wp-content/plugins/*","/wp-content/themes/authentic/*","/*\\?(.+)"]}},{"not":{"selector_matches":"a[rel~=\"nofollow\"]"}},{"not":{"selector_matches":".no-prerender, .no-prerender a"}},{"not":{"selector_matches":".no-prefetch, .no-prefetch a"}}]},"eagerness":"moderate"}]}
</script>
<script>
(function(){

  if (!('IntersectionObserver' in window)) {
    window.initABDInview = function(scope=document){
      scope.querySelectorAll('.df-abd-wrap')
        .forEach(el => el.classList.add('df-abd-inview'));
    };
    window.initABDInview();
    return;
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('df-abd-inview');
        observer.unobserve(entry.target);
      }
    });
  }, {
    rootMargin: "0px 0px -150px 0px"
  });

  // 🔥 fonction globale (clé du fix)
  window.initABDInview = function(scope=document){
    scope.querySelectorAll('.df-abd-wrap:not(.df-abd-inview)')
      .forEach(el => observer.observe(el));
  };

  // init load normal
  document.addEventListener('DOMContentLoaded', function(){
    window.initABDInview(document);
  });

  // 🔥 auto-fix autoload / ajax / infinite scroll
  new MutationObserver((mutations)=>{
    mutations.forEach(m=>{
      m.addedNodes.forEach(node=>{
        if(node.nodeType === 1){
          window.initABDInview(node);
        }
      });
    });
  }).observe(document.body,{
    childList:true,
    subtree:true
  });

})();
</script>

<script>
document.addEventListener('click',function(e){

const btn = e.target;

/* ===============================
   STEP 1 : Reveal hidden posts
================================= */

if(btn.classList.contains('df-load-more')){

    const wrapper = btn.closest('.term-conditional-list');
    if(!wrapper) return;

    wrapper.querySelectorAll('.df-hidden-item')
        .forEach(el => el.style.display='list-item');

    btn.classList.remove('df-load-more');
    btn.classList.add('df-load-more-ajax');
    btn.textContent='Voir encore plus';

    return;
}

/* ===============================
   STEP 2 : AJAX
================================= */

if(btn.classList.contains('df-load-more-ajax')){

    const wrapper = btn.closest('.term-conditional-list');
    if(!wrapper) return;

    const type   = wrapper.dataset.type;
    const id     = wrapper.dataset.id;
    const offset = wrapper.querySelectorAll('li').length;

    btn.disabled = true;
    btn.textContent='Chargement...';

    fetch('https://www.docteur-fitness.com/wp-admin/admin-ajax.php',{
        method:'POST',
        headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body:'action=df_load_more&nonce=c6d741845a&type='+type+'&id='+id+'&offset='+offset
    })
    .then(r=>r.json())
    .then(data=>{

        btn.disabled=false;

        if(!data.success) return;

        if(data.data.end){
            btn.remove();
            wrapper.insertAdjacentHTML('beforeend',
                '<div class="df-loader">🎉 Tu as exploré tous les articles de cette section.<br>N\'hésite pas à lire les dossiers complets ci-desous et à nous suivre sur les réseaux pour ne pas louper les prochains articles !</div>');
            return;
        }

        const ul = wrapper.querySelector('ul');
        ul.insertAdjacentHTML('beforeend', data.data.html);

        /* Animation */
        const newItems = ul.querySelectorAll('.df-fade-in');
        newItems.forEach(el=>{
            requestAnimationFrame(()=>{
                el.classList.add('show');
            });
        });

        btn.textContent='Voir encore plus';
    });

}

});
</script>




        
