:ppt-slide-up .5s ease forwards}.ppt-anim-fade-out{animation:ppt-fade-out .5s ease forwards}.ppt-pulse .ppt-slider{animation:ppt-pulse 2s ease-in-out infinite}.ppt-container { display: flex; justify-content: center; }
